{
  "name": "ini-es",
  "version": "0.3.0",
  "description": "ESM and TypeScript rewrite of [npm/ini](https://github.com/npm/ini)",
  "keywords": [
    "decode",
    "encode",
    "ini",
    "parse",
    "stringify"
  ],
  "homepage": "https://github.com/ntnyq/ini-es#readme",
  "bugs": {
    "url": "https://github.com/ntnyq/ini-es/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "ntnyq/ini-es",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fs": {
      "types": "./dist/fs.d.mts",
      "default": "./dist/fs.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@typescript/native-preview": "7.0.0-dev.20260301.1",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.1.1"
}
